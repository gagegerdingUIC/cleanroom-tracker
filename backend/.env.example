# Copy this file to .env and fill in values for your environment.
# .env is gitignored — never commit real secrets.

# --- Database ---
# Phase 1 (SQLite — default, no changes needed):
DATABASE_URL=sqlite:///./cleanroom.db

# Phase 2 (PostgreSQL — uncomment and fill in):
# DATABASE_URL=postgresql://cleanroom:password@localhost:5432/cleanroom_db

# --- Debug / logging ---
DEBUG=true
SQL_ECHO=false

# --- File storage ---
# Phase 1 (local):
STORAGE_BASE_PATH=./data

# Phase 2 (S3-compatible — uncomment):
# STORAGE_BASE_PATH=s3://your-bucket/cleanroom-data
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_ENDPOINT_URL=http://localhost:9000   # MinIO self-hosted

# --- Auth (dormant in phase 1 — set a real key before phase 2) ---
SECRET_KEY=CHANGE-ME-BEFORE-DEPLOYING
ACCESS_TOKEN_EXPIRE_MINUTES=10080
